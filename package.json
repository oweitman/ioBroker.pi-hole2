{
  "name": "iobroker.pi-hole2",
  "version": "1.2.0",
  "description": "Manage a pi-hole installation",
  "author": {
    "name": "oweitman",
    "email": "oweitman@gmx.de"
  },
  "contributors": [
    {
      "name": "Michael Schuster",
      "email": "development@unltd-networx.de"
    }
  ],
  "homepage": "https://github.com/oweitman/ioBroker.pi-hole2",
  "license": "MIT",
  "keywords": [
    "pi-hole2",
    "ioBroker",
    "ioBroker-adapter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/oweitman/ioBroker.pi-hole2.git"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.13.14",
    "nyc": "^18.0.0",
    "typescript": "~5.9.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|eslint.config.mjs|prettier.config.mjs).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "coverage": "nyc npm run test:js && nyc report --reporter=lcovonly --reporter=html",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs .",
    "repochecker": "npx @iobroker/repochecker https://github.com/oweitman/ioBroker.pi-hole2 --local --noinfo",
    "translate": "translate-adapter",
    "release": "release-script --all"
  },
  "bugs": {
    "url": "https://github.com/oweitman/ioBroker.pi-hole2/issues"
  },
  "readmeFilename": "README.md"
}
